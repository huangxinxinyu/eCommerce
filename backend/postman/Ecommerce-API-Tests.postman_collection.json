    {
      "name": "Integration Tests",
      "item": [
        {
          "name": "完整秒杀流程测试",
          "item": [
            {
              "name": "Step 1: 注册用户",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "var jsonData = pm.response.json();",
                      "if (jsonData.code === 200 && jsonData.data && jsonData.data.userId) {",
                      "    pm.collectionVariables.set('testUserId', jsonData.data.userId);",
                      "    console.log('用户注册成功，userId:', jsonData.data.userId);",
                      "} else {",
                      "    console.log('用户已存在或注册失败，使用默认userId');",
                      "    pm.collectionVariables.set('testUserId', '100');",
                      "}"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n    \"username\": \"seckill_user\",\n    \"email\": \"seckill@example.com\",\n    \"phone\": \"13900139001\"\n}"
                },
                "url": {
                  "raw": "http://localhost:8080/api/user/register",
                  "protocol": "http",
                  "host": ["localhost"],
                  "port": "8080",
                  "path": ["api", "user", "register"]
                }
              },
              "response": []
            },
