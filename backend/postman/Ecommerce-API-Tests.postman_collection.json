              "raw": "{\n    \"username\": \"testuser001\",\n    \"email\": \"test001@example.com\",\n    \"phone\": \"13800138000\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/user/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
